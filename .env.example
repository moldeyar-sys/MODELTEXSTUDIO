# ============================================================
# Moldey Global - Variables de entorno (ejemplo)
# Copiá este archivo a ".env" y completá los valores reales.
# NO subas ".env" al repositorio.
# ============================================================

# --- Supabase (OBLIGATORIAS - frontend) ---
# Visibles en el cliente: solo usar la URL pública y la anon key.
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=tu-anon-key-aqui

# --- Pasarelas de pago (OPCIONALES - solo backend/Edge Functions) ---
# IMPORTANTE: estos son SECRETOS de servidor. No deben llevar el prefijo
# VITE_ ni usarse desde el frontend (quedarían expuestos en el bundle).
# Configurarlos como secrets de Supabase Edge Functions cuando se integren.
MERCADO_PAGO_ACCESS_TOKEN=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
STRIPE_SECRET_KEY=
